---
import { SITE_TITLE } from '../consts';
---

<header>
	<nav>
		<h2 class="brand"><a href="/">Bwire Rodney</a></h2>
		<div class="internal-links" aria-label="Primary">
			<a href="#home">Home</a>
			<a href="#services">Services</a>
			<a href="#about">About</a>
			<a href="#skills">Skills</a>
		</div>
		<div class="header-cta">
			<a href="#contact" class="cta-btn">Let's Talk</a>
		</div>
	</nav>
</header>
<style>
	header {
		position: sticky;
		top: 0;
		z-index: 20;
		padding: 0.75rem clamp(1rem, 3vw, 3rem);
		background: rgba(22, 10, 28, 0.72);
		backdrop-filter: blur(12px);
		border-bottom: 1px solid rgba(255, 179, 71, 0.2);
	}
	h2,
	.brand {
		margin: 0;
		font-size: 1.1rem;
	}
	.brand a {
		text-decoration: none;
		color: #ffbe4d;
		letter-spacing: 0.02em;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
	}
	.internal-links {
		display: flex;
		gap: 1rem;
	}
	.internal-links a {
		padding: 0.45rem 0.6rem;
		color: #f3dec5;
		font-size: 0.95rem;
		font-weight: 700;
		border-radius: 999px;
		border: 1px solid transparent;
		text-decoration: none;
		transition: border-color 180ms ease, color 180ms ease, background-color 180ms ease;
	}
	.internal-links a:hover {
		color: #ffbe4d;
		border-color: rgba(255, 190, 77, 0.45);
		background: rgba(255, 190, 77, 0.08);
	}
	.cta-btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.6rem 1rem;
		border-radius: 999px;
		font-weight: 700;
		font-size: 0.9rem;
		color: #25190b;
		text-decoration: none;
		background: linear-gradient(120deg, #ff9e17, #ffd265);
		box-shadow: 0 10px 24px rgba(255, 150, 20, 0.25);
	}
	@media (max-width: 900px) {
		.internal-links {
			display: none;
		}
	}
	@media (max-width: 540px) {
		header {
			padding-inline: 1rem;
		}
		.cta-btn {
			padding-inline: 0.85rem;
		}
	}
</style>
