---
const isHomePage = Astro.url.pathname === '/';
const sectionHref = (id: string) => (isHomePage ? `#${id}` : `/#${id}`);
---

<header>
	<nav>
		<h2 class="brand"><a href="/">Bwire Rodney</a></h2>
		<div class="internal-links" aria-label="Primary">
			<a class="section-link" href={sectionHref('home')}>Home</a>
			<a class="section-link" href={sectionHref('services')}>Services</a>
			<a class="section-link" href={sectionHref('about')}>About</a>
			<a class="section-link" href={sectionHref('skills')}>Skills</a>
		</div>
		<div class="header-cta">
			<a href={sectionHref('contact')} class="cta-btn section-link">Let's Talk</a>
		</div>
	</nav>
</header>
<script is:inline>
	const isHome = window.location.pathname === '/';
	if (isHome) {
		const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
		const navLinks = document.querySelectorAll('.section-link[href^="#"]');

		const animateTarget = (target) => {
			if (reduceMotion || !target || typeof target.animate !== 'function') return;
			target.animate(
				[
					{ opacity: 0.72, transform: 'translateY(10px) scale(0.995)', filter: 'brightness(0.94)' },
					{ opacity: 1, transform: 'translateY(0) scale(1)', filter: 'brightness(1)' }
				],
				{
					duration: 760,
					easing: 'cubic-bezier(0.22, 1, 0.36, 1)',
					fill: 'both'
				}
			);
		};

		for (const link of navLinks) {
			link.addEventListener('click', (event) => {
				const href = link.getAttribute('href');
				if (!href || !href.startsWith('#')) return;

				const target = document.querySelector(href);
				if (!target) return;

				event.preventDefault();
				const header = document.querySelector('header');
				const headerHeight = header ? header.getBoundingClientRect().height : 0;
				const targetTop = target.getBoundingClientRect().top + window.scrollY - headerHeight - 12;

				window.scrollTo({
					top: Math.max(0, targetTop),
					behavior: reduceMotion ? 'auto' : 'smooth'
				});

				window.history.replaceState(null, '', href);
				window.setTimeout(() => animateTarget(target), reduceMotion ? 0 : 220);
			});
		}
	}
</script>
<style>
	header {
		position: sticky;
		top: 0;
		z-index: 20;
		padding: 0.75rem clamp(1rem, 3vw, 3rem);
		background: rgba(22, 10, 28, 0.72);
		backdrop-filter: blur(12px);
		border-bottom: 1px solid rgba(255, 179, 71, 0.2);
	}
	h2,
	.brand {
		margin: 0;
		font-size: 1.1rem;
	}
	.brand a {
		text-decoration: none;
		color: #ffbe4d;
		letter-spacing: 0.02em;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
	}
	.internal-links {
		display: flex;
		gap: 1rem;
	}
	.internal-links a {
		padding: 0.45rem 0.6rem;
		color: #f3dec5;
		font-size: 0.95rem;
		font-weight: 700;
		border-radius: 999px;
		border: 1px solid transparent;
		text-decoration: none;
		transition: border-color 180ms ease, color 180ms ease, background-color 180ms ease;
	}
	.internal-links a:hover {
		color: #ffbe4d;
		border-color: rgba(255, 190, 77, 0.45);
		background: rgba(255, 190, 77, 0.08);
	}
	.cta-btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.6rem 1rem;
		border-radius: 999px;
		font-weight: 700;
		font-size: 0.9rem;
		color: #25190b;
		text-decoration: none;
		background: linear-gradient(120deg, #ff9e17, #ffd265);
		box-shadow: 0 10px 24px rgba(255, 150, 20, 0.25);
	}
	@media (max-width: 900px) {
		.internal-links {
			display: none;
		}
	}
	@media (max-width: 540px) {
		header {
			padding-inline: 1rem;
		}
		.cta-btn {
			padding-inline: 0.85rem;
		}
	}
</style>
