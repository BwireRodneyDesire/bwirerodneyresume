---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			@keyframes postRise {
				from {
					opacity: 0;
					transform: translateY(26px) scale(0.994);
				}
				to {
					opacity: 1;
					transform: translateY(0) scale(1);
				}
			}
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
			}
			article {
				opacity: 0;
				transform: translateY(20px);
				will-change: transform, opacity;
				animation: postRise 840ms cubic-bezier(0.22, 1, 0.36, 1) 90ms forwards;
			}
			.hero-image {
				width: 100%;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
			}
			.prose {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
				color: rgb(var(--gray-dark));
			}
			.title {
				margin-bottom: 1em;
				padding: 1em 0;
				text-align: center;
				line-height: 1;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
			}
			.post-description {
				max-width: 65ch;
				margin: 0 auto 1rem;
				line-height: 1.5;
				color: rgb(var(--gray-dark));
			}
			.date {
				margin-bottom: 0.5em;
				color: rgb(var(--gray));
			}
			.last-updated-on {
				font-style: italic;
			}

			.prose :global(.content-reveal) {
				opacity: 0;
				transform: translateY(18px);
				transition:
					opacity 760ms cubic-bezier(0.22, 1, 0.36, 1),
					transform 760ms cubic-bezier(0.22, 1, 0.36, 1);
				transition-delay: var(--reveal-delay, 0ms);
			}
			.prose :global(.content-reveal.in-view) {
				opacity: 1;
				transform: translateY(0);
			}
			@media (prefers-reduced-motion: reduce) {
				article {
					animation: none;
					opacity: 1;
					transform: none;
				}
				.prose :global(.content-reveal) {
					opacity: 1;
					transform: none;
					transition: none;
				}
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image">
					{heroImage && <img width={1020} height={510} src={heroImage} alt={`Hero image for ${title}`} />}
				</div>
				<div class="prose">
					<div class="title">
						<div class="date">
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<div class="last-updated-on">
										Last updated on <FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
						<h1>{title}</h1>
						<p class="post-description">{description}</p>
						<hr />
					</div>
					<slot />
				</div>
			</article>
		</main>
		<script is:inline>
			const targets = document.querySelectorAll(
				'.prose p, .prose h2, .prose h3, .prose li, .prose blockquote, .prose pre, .prose img'
			);

			for (const el of targets) {
				el.classList.add('content-reveal');
			}

			targets.forEach((el, index) => {
				const delay = Math.min(index * 36, 260);
				el.style.setProperty('--reveal-delay', `${delay}ms`);
			});

			if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
				const io = new IntersectionObserver(
					(entries) => {
						for (const entry of entries) {
							if (entry.isIntersecting) {
								entry.target.classList.add('in-view');
								io.unobserve(entry.target);
							}
						}
					},
					{ threshold: 0.12, rootMargin: '0px 0px -8% 0px' }
				);

				for (const el of targets) {
					io.observe(el);
				}
			}
		</script>
		<Footer />
	</body>
</html>
