---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="-main">
			<section id="home" class="hero section-shell">
				<div class="hero-copy">
					<p class="welcome-chip reveal delay-1">
						<span class="welcome-typing">Welcome. Let us build something real.</span>
					</p>
					<h1 class="hero-title reveal delay-2">
						Hi, I&apos;m <span>Bwire Rodney</span>
					</h1>
					<p class="hero-subtitle reveal delay-3">Full-Stack Developer and UI/UX Enthusiast</p>
					<p class="hero-text reveal delay-4">
						I craft digital products that blend clean engineering with thoughtful design.
						Let&apos;s turn your idea into a scalable, polished experience.
					</p>
					<div class="hero-actions reveal delay-5">
						<a class="btn btn-primary" href="#contact">Contact Me</a>
						<a class="btn btn-secondary" href="/about">About My Work</a>
					</div>
					<div class="hero-stats reveal delay-6" aria-label="Portfolio highlights">
						<div><strong>50+</strong><span>Projects</span></div>
						<div><strong>4+</strong><span>Years</span></div>
						
					</div>
				</div>
				<div class="hero-media reveal delay-4">
					<div class="portrait-wrap">
						<img src="/images/bwirerodneyportrait.jpeg" alt="Portrait of Bwire Rodney" />
					</div>
				</div>
			</section>

			<section id="services" class="section-shell">
				<div class="section-head">
					<p class="section-kicker">What I Offer</p>
					<h2>My Services</h2>
				</div>
				<div class="service-grid">
					<article class="service-card">
						<h3>Web Development</h3>
						<p>Fast, maintainable web apps with modern front-end and robust APIs.</p>
					</article>
					<article class="service-card">
						<h3>UI/UX Design</h3>
						<p>Human-centered interfaces designed for clarity, trust, and conversion.</p>
					</article>
					<article class="service-card">
						<h3>Mobile Experiences</h3>
						<p>Responsive and mobile-first layouts that feel native on every device.</p>
					</article>
					<article class="service-card">
						<h3>Backend Systems</h3>
						<p>Secure services, optimized data models, and clean architecture.</p>
					</article>
					<article class="service-card">
						<h3>Technical Writing</h3>
						<p>Clear docs and developer guides that reduce friction for your team.</p>
					</article>
					<article class="service-card">
						<h3>Performance Audits</h3>
						<p>Code and UX audits focused on speed, accessibility, and stability.</p>
					</article>
				</div>
			</section>

			<section id="about" class="section-shell about-layout">
				<div class="about-gallery" aria-label="Selected project visuals">
					<img src="/images/dino.jpeg" alt="Portrait of Bwire Rodney near coding desk" />
					<img src="/images/portraitbwire.jpeg" alt="Profile portrait of Bwire Rodney" />
					<img src="/images/bwire-portrait.jpeg" alt="Workspace and coding setup" />
				</div>
				<div class="about-copy">
					<p class="section-kicker">About Me</p>
					<h2>Design-minded developer with product focus</h2>
					<p>
						I build with both users and systems in mind. My workflow combines rapid prototyping,
						careful implementation, and iterative refinement so products stay useful as they grow.
					</p>
					<div class="pill-row">
						<span>Frontend</span>
						<span>Backend</span>
						<span>Design Systems</span>
						<span>API Integration</span>
					</div>
					<div class="hero-actions">
						<a class="btn btn-primary" href="/blog">View Insights</a>
						<a class="btn btn-secondary" href="#contact">Start a Project</a>
					</div>
				</div>
			</section>

			<section id="skills" class="section-shell section-compact">
				<div class="section-head">
					<p class="section-kicker">Skills and Experience</p>
					<h2>Turning complex requirements into simple outcomes</h2>
				</div>
			</section>

			<section id="contact" class="section-shell section-compact contact-block">
				<h2>Let&apos;s build something meaningful</h2>
				<p>I&apos;m available for freelance and full-time opportunities.</p>
				<a class="btn btn-primary" href="bwirerodney3@gmail.com">Bwirerodney3@gmail.com</a>
			</section>
		</main>
		<Footer />
	</body>
</html>
