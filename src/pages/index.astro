---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="portfolio-main">
			<section id="home" class="hero section-shell">
				<div class="hero-copy">
					<p class="welcome-chip reveal delay-1">
						<span class="welcome-typing">Welcome. Let us build something real.</span>
					</p>
					<h1 class="hero-title reveal delay-2">
						Hi, I&apos;m <span>Bwire Rodney</span>
					</h1>
					<p class="hero-subtitle reveal delay-3">Full-Stack Developer and UI/UX Enthusiast</p>
					<p class="hero-text reveal delay-4">
						I craft digital products that blend clean engineering with thoughtful design.
						Let&apos;s turn your idea into a scalable, polished experience.
					</p>
					<div class="hero-actions reveal delay-5">
						<a class="btn btn-primary" href="#contact">Contact Me</a>
						<a class="btn btn-secondary" href="/about">About My Work</a>
					</div>
					<div class="hero-stats reveal delay-6" aria-label="Portfolio highlights">
						<div><strong>7+</strong><span>Projects</span></div>
						<div><strong>2+</strong><span>Years</span></div>
						
					</div>
				</div>
				<div class="hero-media reveal delay-4">
					<div class="portrait-wrap">
						<img src="/images/bwirerodneyportrait.jpeg" alt="Portrait of Bwire Rodney" />
					</div>
				</div>
			</section>

			<section id="services" class="section-shell">
				<div class="section-head">
					<p class="section-kicker">What I Offer</p>
					<h2>My Services</h2>
				</div>
				<div class="service-grid">
					<article class="service-card">
						<h3>Web Development</h3>
						<p>Fast, maintainable web apps with modern front-end and robust APIs.</p>
					</article>
					<article class="service-card">
						<h3>UI/UX Design</h3>
						<p>Human-centered interfaces designed for clarity, trust, and conversion.</p>
					</article>
					<article class="service-card">
						<h3>Mobile Experiences</h3>
						<p>Responsive and mobile-first layouts that feel native on every device.</p>
					</article>
					<article class="service-card">
						<h3>Backend Systems</h3>
						<p>Secure services, optimized data models, and clean architecture.</p>
					</article>
					<article class="service-card">
						<h3>Technical Writing</h3>
						<p>Clear docs and developer guides that reduce friction for your team.</p>
					</article>
					<article class="service-card">
						<h3>Performance Audits</h3>
						<p>Code and UX audits focused on speed, accessibility, and stability.</p>
					</article>
				</div>
			</section>

			<section id="about" class="section-shell about-layout">
				<div class="about-gallery" aria-label="Selected project visuals">
					<img src="/images/dino.jpeg" alt="Portrait of Bwire Rodney near coding desk" />
					<img src="/images/portraitbwire.jpeg" alt="Profile portrait of Bwire Rodney" />
					<img src="/images/bwire-portrait.jpeg" alt="Workspace and coding setup" />
				</div>
				<div class="about-copy">
					<p class="section-kicker">About Me</p>
					<h2>Design-minded developer with product focus</h2>
					<p>
						I build with both users and systems in mind. My workflow combines rapid prototyping,
						careful implementation, and iterative refinement so products stay useful as they grow.
					</p>
					<div class="pill-row">
						<span>Frontend</span>
						<span>Backend</span>
						<span>Design Systems</span>
						<span>API Integration</span>
					</div>
					<div class="hero-actions">
						<a class="btn btn-primary" id="view-insights-link" href="/blog">View Insights</a>
						<a class="btn btn-secondary" href="#contact">Start a Project</a>
					</div>
				</div>
			</section>

			<section id="skills" class="section-shell section-compact">
				<div class="section-head">
					<p class="section-kicker">Skills and Experience</p>
					<h2>Turning complex requirements into simple outcomes</h2>
				</div>
			</section>

			<section id="contact" class="section-shell section-compact contact-block">
				<h2>Let&apos;s build something meaningful</h2>
				<p>I&apos;m available for freelance and full-time opportunities.</p>
				<div class="contact-actions reveal delay-4">
					<a class="btn btn-primary contact-btn email-btn" href="mailto:bwirerodney3@gmail.com" aria-label="Send email to Bwire Rodney">
						<svg viewBox="0 0 24 24" aria-hidden="true" width="18" height="18">
							<path fill="currentColor" d="M3 5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5Zm2 .5V6l7 5 7-5v-.5H5Zm14 13V8.44l-6.42 4.58a1 1 0 0 1-1.16 0L5 8.44V18.5h14Z"/>
						</svg>
						<span>Email Me</span>
					</a>
					<a class="btn btn-secondary contact-btn whatsapp-btn" href="https://wa.me/256751550227" target="_blank" rel="noopener noreferrer" aria-label="Chat on WhatsApp with Bwire Rodney">
						<svg viewBox="0 0 24 24" aria-hidden="true" width="18" height="18">
							<path fill="currentColor" d="M20.52 3.48A11.9 11.9 0 0 0 12.04 0C5.47 0 .14 5.32.14 11.89c0 2.09.54 4.13 1.57 5.93L0 24l6.33-1.66a11.86 11.86 0 0 0 5.7 1.45h.01c6.56 0 11.89-5.32 11.89-11.89 0-3.17-1.24-6.15-3.41-8.42ZM12.04 21.8h-.01a9.9 9.9 0 0 1-5.03-1.37l-.36-.22-3.75.98 1-3.66-.24-.38a9.89 9.89 0 0 1-1.52-5.26c0-5.46 4.44-9.9 9.91-9.9 2.64 0 5.12 1.03 6.99 2.91a9.83 9.83 0 0 1 2.9 6.99c0 5.46-4.44 9.91-9.89 9.91Zm5.43-7.42c-.3-.15-1.78-.88-2.05-.98-.27-.1-.46-.15-.66.15-.2.3-.76.97-.93 1.17-.17.2-.35.22-.64.07-.3-.15-1.25-.46-2.38-1.46-.88-.79-1.47-1.76-1.65-2.06-.17-.3-.02-.46.13-.61.13-.13.3-.35.44-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.08-.15-.66-1.6-.91-2.2-.24-.58-.48-.5-.66-.5h-.56c-.2 0-.52.08-.79.37-.27.3-1.04 1.01-1.04 2.46s1.07 2.86 1.22 3.06c.15.2 2.1 3.2 5.09 4.48.71.3 1.27.48 1.7.62.71.22 1.36.19 1.87.11.57-.08 1.78-.73 2.03-1.44.25-.71.25-1.32.17-1.44-.07-.12-.27-.2-.57-.35Z"/>
						</svg>
						<span>WhatsApp</span>
					</a>
					<a class="btn btn-secondary contact-btn phone-btn" href="tel:+256751550227" aria-label="Call Bwire Rodney on 0751550227">
						<svg viewBox="0 0 24 24" aria-hidden="true" width="18" height="18">
							<path fill="currentColor" d="M6.62 10.79a15.07 15.07 0 0 0 6.59 6.59l2.2-2.2a1 1 0 0 1 1.01-.24c1.11.37 2.3.57 3.53.57a1 1 0 0 1 1 1V20a1 1 0 0 1-1 1C10.85 21 3 13.15 3 3.99a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1c0 1.23.2 2.42.57 3.53a1 1 0 0 1-.25 1.02l-2.2 2.25Z"/>
						</svg>
						<span>Call 0751550227</span>
					</a>
				</div>
			</section>
		</main>
		<script is:inline>
			// Premium scroll animation for anchor links
			const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

			// Handle smooth scrolling with arrival animations
			const setupSmoothScroll = () => {
				const anchorLinks = document.querySelectorAll('a[href^="#"]');
				const animateTarget = (target) => {
					if (reduceMotion || !target || typeof target.animate !== 'function') return;
					target.animate(
						[
							{ opacity: 0.72, transform: 'translateY(10px) scale(0.995)', filter: 'brightness(0.94)' },
							{ opacity: 1, transform: 'translateY(0) scale(1)', filter: 'brightness(1)' }
						],
						{ duration: 760, easing: 'cubic-bezier(0.22, 1, 0.36, 1)', fill: 'both' }
					);
				};

				for (const link of anchorLinks) {
					link.addEventListener('click', (e) => {
						const href = link.getAttribute('href');
						if (!href || href.startsWith('http') || href.startsWith('mailto:') || href.startsWith('tel:')) return;

						const target = document.querySelector(href);
						if (!target) return;

						e.preventDefault();
						const header = document.querySelector('header');
						const headerHeight = header ? header.getBoundingClientRect().height : 0;
						const targetTop = target.getBoundingClientRect().top + window.scrollY - headerHeight - 12;

						window.scrollTo({
							top: Math.max(0, targetTop),
							behavior: reduceMotion ? 'auto' : 'smooth'
						});

						window.history.replaceState(null, '', href);
						window.setTimeout(() => animateTarget(target), reduceMotion ? 0 : 220);
					});
				}
			};

			// Setup scroll reveal for sections
			const setupSectionReveal = () => {
				const sections = document.querySelectorAll('.portfolio-main section');
				if (reduceMotion || !IntersectionObserver) return;

				const observer = new IntersectionObserver(
					(entries) => {
						for (const entry of entries) {
							if (entry.isIntersecting) {
								entry.target.style.animation = 'sectionSlide 820ms cubic-bezier(0.22, 1, 0.36, 1) both';
								observer.unobserve(entry.target);
							}
						}
					},
					{ threshold: 0.06, rootMargin: '0px 0px -12% 0px' }
				);

				for (const section of sections) {
					section.style.opacity = '0';
					section.style.transform = 'translateY(24px)';
					observer.observe(section);
				}
			};

			// Add section slide animation to styles
			if (!document.querySelector('style[data-scroll-animations]')) {
				const style = document.createElement('style');
				style.setAttribute('data-scroll-animations', 'true');
				style.textContent = `
					@keyframes sectionSlide {
						from { opacity: 0; transform: translateY(24px); }
						to { opacity: 1; transform: translateY(0); }
					}
				`;
				document.head.appendChild(style);
			}

			const insightsLink = document.getElementById('view-insights-link');
			if (insightsLink) {
				insightsLink.addEventListener('click', () => {
					window.sessionStorage.setItem('insights-entry-transition', '1');
				});
			}

			setupSmoothScroll();
			setupSectionReveal();
		</script>
		<Footer />
	</body>
</html>